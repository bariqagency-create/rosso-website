# ROSSO — Environment Variables Example
# Copy this file to .env.local and fill in real values.

# WhatsApp number that receives booking submissions (no +, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=201101139997

# Public site URL (used for canonical links, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://rosso.auto

# Password required to open /dashboard (client-side gate; not for high-security data)
NEXT_PUBLIC_DASHBOARD_PASSWORD=change-me

# Optional — analytics IDs
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
